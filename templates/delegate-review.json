{
  "Id": "delegate-review",
  "Name": "Delegate a review to a local model",
  "IsActive": false,
  "Nodes": [
    {
      "Id": "t",
      "TypeId": "cockpit.manual",
      "Name": "Run it",
      "X": 80,
      "Y": 200
    },
    {
      "Id": "d",
      "TypeId": "cockpit.command",
      "Name": "The diff",
      "X": 320,
      "Y": 200,
      "Parameters": {
        "Command": "git diff --staged",
        "Working directory": ""
      }
    },
    {
      "Id": "r",
